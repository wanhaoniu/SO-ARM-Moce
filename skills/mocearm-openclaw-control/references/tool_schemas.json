        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill name, e.g. dance_short or grasp_apple_mock"
          },
          "params": {
            "type": "object",
            "description": "Optional parameters for selected skill",
            "additionalProperties": true
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    }
  }
