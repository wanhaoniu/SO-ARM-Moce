          },
          "z": {
            "type": "number",
            "description": "Target z in meters"
          },
          "frame": {
            "type": "string",
            "enum": [
              "base",
              "tool"
            ],
            "default": "base"
          },
          "duration": {
            "type": "number",
            "minimum": 0.2,
            "maximum": 20.0,
            "default": 2.0
          },
          "wait": {
            "type": "boolean",
            "default": true
          }
        },
        "required": [
          "x",
          "y",
          "z"
        ],
        "additionalProperties": false
      }
    }
  },
